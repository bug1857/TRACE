# TRACE Environment Variables
# Copy this file to .env.local (frontend) and set backend vars on Render.
# Never commit .env.local or real secrets.

# ─── Backend ──────────────────────────────────────────────────────────────────
# Local: sqlite:///./trace.db
# Production (Render): automatically injected by Render — do not set manually
DATABASE_URL=sqlite:///./trace.db

# Secret key for signing tokens. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# Max upload size in MB
MAX_UPLOAD_MB=50

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# NEXT_PUBLIC_ prefix required for browser-side access
# Local dev
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: set to your Render backend URL, e.g. https://trace-backend.onrender.com
